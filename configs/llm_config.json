{
  "model_type": "causal_lm",
  "model_name": "Agricultural-LLM-Qwen-7B",
  "base_model": "Qwen/Qwen2.5-7B",
  
  "data": {
    "train_path": "${SCRATCH}/growai-hpc/data/llm_training.jsonl",
    "eval_path": "${SCRATCH}/growai-hpc/data/llm_eval.jsonl",
    "max_seq_length": 2048
  },
  
  "quantization": {
    "load_in_4bit": true,
    "bnb_4bit_compute_dtype": "bfloat16",
    "bnb_4bit_use_double_quant": true,
    "bnb_4bit_quant_type": "nf4"
  },
  
  "lora": {
    "r": 64,
    "lora_alpha": 16,
    "target_modules": [
      "q_proj", "k_proj", "v_proj", "o_proj",
      "gate_proj", "up_proj", "down_proj"
    ],
    "lora_dropout": 0.05,
    "bias": "none",
    "task_type": "CAUSAL_LM"
  },
  
  "training": {
    "num_train_epochs": 3,
    "per_device_train_batch_size": 2,
    "per_device_eval_batch_size": 2,
    "gradient_accumulation_steps": 4,
    "learning_rate": 0.0002,
    "weight_decay": 0.001,
    "warmup_ratio": 0.03,
    "lr_scheduler_type": "cosine",
    "max_grad_norm": 0.3,
    "group_by_length": true,
    "bf16": true,
    "gradient_checkpointing": true,
    "optim": "paged_adamw_8bit"
  },
  
  "deepspeed": {
    "stage": 2,
    "offload_optimizer": false,
    "allgather_partitions": true,
    "allgather_bucket_size": 200000000,
    "overlap_comm": true,
    "reduce_scatter": true,
    "reduce_bucket_size": 200000000
  },
  
  "output": {
    "checkpoint_dir": "${WORK}/growai-hpc/checkpoints/llm",
    "log_dir": "${WORK}/growai-hpc/logs/llm",
    "save_steps": 500,
    "eval_steps": 500,
    "logging_steps": 10,
    "save_total_limit": 3
  }
}
