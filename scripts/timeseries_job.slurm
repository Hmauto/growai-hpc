#!/bin/bash
# =============================================================================
# SLURM Job Script: Time Series Forecasting Model Training
# =============================================================================
# This script submits the TFT training job to CINECA Leonardo.
#
# Submit with: sbatch timeseries_job.slurm
# Monitor with: squeue -u $USER
# Cancel with: scancel <job_id>
# =============================================================================

# -----------------------------------------------------------------------------
# SLURM Directives
# -----------------------------------------------------------------------------
#SBATCH --job-name=growai-timeseries
#SBATCH --output=../logs/timeseries_%j.out
#SBATCH --error=../logs/timeseries_%j.err
#SBATCH --time=04:00:00
#SBATCH --partition=boost_usr_prod
#SBATCH --nodes=1
#SBATCH --ntasks-per-node=1
#SBATCH --gpus-per-node=4
#SBATCH --cpus-per-task=32
#SBATCH --mem=120G
#SBATCH --mail-type=BEGIN,END,FAIL
#SBATCH --mail-user=$USER@cineca.it

# -----------------------------------------------------------------------------
# Environment Setup
# -----------------------------------------------------------------------------
echo "========================================"
echo "Job started at: $(date)"
echo "Running on host: $(hostname)"
echo "SLURM_JOB_ID: $SLURM_JOB_ID"
echo "SLURM_NODELIST: $SLURM_NODELIST"
echo "CUDA_VISIBLE_DEVICES: $CUDA_VISIBLE_DEVICES"
echo "========================================"

# Load modules
module purge
module load profile/deeplearning
module load cuda/12.2
module load cudnn/8.9.7.29-cuda-12.2
module load nccl/2.18.5-cuda-12.2
module load gcc/12.2.0

# Source conda
source "${CONDA_DIR}/etc/profile.d/conda.sh" 2>/dev/null || \
source "${HOME}/.conda/etc/profile.d/conda.sh" 2>/dev/null || \
module load anaconda3

# Activate environment
conda activate growai-hpc

# Verify environment
echo "Python: $(which python)"
echo "Python version: $(python --version)"
echo "PyTorch version: $(python -c 'import torch; print(torch.__version__)')"
echo "CUDA available: $(python -c 'import torch; print(torch.cuda.is_available())')"
echo "GPU count: $(python -c 'import torch; print(torch.cuda.device_count())')"

# -----------------------------------------------------------------------------
# Configuration
# -----------------------------------------------------------------------------
WORK_DIR="${WORK}/growai-hpc"
SCRATCH_DIR="${SCRATCH}/growai-hpc"
SRC_DIR="${WORK_DIR}/src"
CONFIG_DIR="${WORK_DIR}/configs"
DATA_DIR="${SCRATCH_DIR}/data"
CHECKPOINT_DIR="${WORK_DIR}/checkpoints/timeseries"
LOG_DIR="${WORK_DIR}/logs/timeseries"

# Create directories
mkdir -p "${CHECKPOINT_DIR}"
mkdir -p "${LOG_DIR}"
mkdir -p "${DATA_DIR}"

# -----------------------------------------------------------------------------
# Data Preparation (if needed)
# -----------------------------------------------------------------------------
if [ ! -f "${DATA_DIR}/sensors.csv" ]; then
    echo "Sensor data not found. It will be generated by the training script."
fi

# -----------------------------------------------------------------------------
# Training
# -----------------------------------------------------------------------------
echo "========================================"
echo "Starting Time Series Training..."
echo "========================================"

# Set environment variables for distributed training
export PYTHONFAULTHANDLER=1
export CUDA_LAUNCH_BLOCKING=0
export NCCL_DEBUG=INFO
export NCCL_IB_DISABLE=0
export NCCL_SOCKET_IFNAME=ib0

# Run training
python "${SRC_DIR}/train_timeseries.py" \
    --data "${DATA_DIR}/sensors.csv" \
    --checkpoint-dir "${CHECKPOINT_DIR}" \
    --epochs 100 \
    --batch-size 128 \
    --gpus 4

TRAINING_EXIT_CODE=$?

# -----------------------------------------------------------------------------
# Post-processing
# -----------------------------------------------------------------------------
if [ $TRAINING_EXIT_CODE -eq 0 ]; then
    echo "========================================"
    echo "Training completed successfully!"
    echo "========================================"
    
    # Sync checkpoints to permanent storage
    if [ -d "${CHECKPOINT_DIR}" ]; then
        echo "Syncing checkpoints..."
        rsync -av --progress "${CHECKPOINT_DIR}/" "${WORK_DIR}/checkpoints_backup/timeseries_${SLURM_JOB_ID}/"
    fi
    
    # Copy logs
    cp "${LOG_DIR}"/*.log "${WORK_DIR}/logs/" 2>/dev/null || true
    
    # Generate summary
    python << EOF
import json
import os

checkpoint_dir = "${CHECKPOINT_DIR}"
metrics_path = os.path.join(checkpoint_dir, "metrics.json")

if os.path.exists(metrics_path):
    with open(metrics_path, 'r') as f:
        metrics = json.load(f)
    print("\nTraining Metrics:")
    print("-" * 40)
    for key, value in metrics.items():
        if isinstance(value, (int, float)):
            print(f"  {key}: {value:.4f}")
else:
    print("Metrics file not found.")
EOF

else
    echo "========================================"
    echo "Training failed with exit code: $TRAINING_EXIT_CODE"
    echo "========================================"
fi

# -----------------------------------------------------------------------------
# Cleanup and Exit
# -----------------------------------------------------------------------------
echo "========================================"
echo "Job finished at: $(date)"
echo "========================================"

exit $TRAINING_EXIT_CODE
