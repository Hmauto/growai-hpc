#!/bin/bash
# =============================================================================
# SLURM Job Script: Crop Recommendation Model Training
# =============================================================================
# This script submits the XGBoost/NN training job to CINECA Leonardo.
#
# Submit with: sbatch recommendation_job.slurm
# Monitor with: squeue -u $USER
# Cancel with: scancel <job_id>
# =============================================================================

# -----------------------------------------------------------------------------
# SLURM Directives
# -----------------------------------------------------------------------------
#SBATCH --job-name=growai-recommendation
#SBATCH --output=../logs/recommendation_%j.out
#SBATCH --error=../logs/recommendation_%j.err
#SBATCH --time=02:00:00
#SBATCH --partition=boost_usr_prod
#SBATCH --nodes=1
#SBATCH --ntasks-per-node=1
#SBATCH --gpus-per-node=2
#SBATCH --cpus-per-task=16
#SBATCH --mem=64G
#SBATCH --mail-type=BEGIN,END,FAIL
#SBATCH --mail-user=$USER@cineca.it

# -----------------------------------------------------------------------------
# Environment Setup
# -----------------------------------------------------------------------------
echo "========================================"
echo "Job started at: $(date)"
echo "Running on host: $(hostname)"
echo "SLURM_JOB_ID: $SLURM_JOB_ID"
echo "SLURM_NODELIST: $SLURM_NODELIST"
echo "CUDA_VISIBLE_DEVICES: $CUDA_VISIBLE_DEVICES"
echo "========================================"

# Load modules
module purge
module load profile/deeplearning
module load cuda/12.2
module load cudnn/8.9.7.29-cuda-12.2
module load gcc/12.2.0

# Source conda
source "${CONDA_DIR}/etc/profile.d/conda.sh" 2>/dev/null || \
source "${HOME}/.conda/etc/profile.d/conda.sh" 2>/dev/null || \
module load anaconda3

# Activate environment
conda activate growai-hpc

# Verify environment
echo "Python: $(which python)"
echo "Python version: $(python --version)"

# -----------------------------------------------------------------------------
# Configuration
# -----------------------------------------------------------------------------
WORK_DIR="${WORK}/growai-hpc"
SCRATCH_DIR="${SCRATCH}/growai-hpc"
SRC_DIR="${WORK_DIR}/src"
CONFIG_DIR="${WORK_DIR}/configs"
DATA_DIR="${SCRATCH_DIR}/data"
CHECKPOINT_DIR="${WORK_DIR}/checkpoints/recommendation"
LOG_DIR="${WORK_DIR}/logs/recommendation"

# Create directories
mkdir -p "${CHECKPOINT_DIR}"
mkdir -p "${LOG_DIR}"
mkdir -p "${DATA_DIR}"

# -----------------------------------------------------------------------------
# Data Preparation (if needed)
# -----------------------------------------------------------------------------
if [ ! -f "${DATA_DIR}/crop_data.csv" ]; then
    echo "Crop data not found. It will be generated by the training script."
fi

# -----------------------------------------------------------------------------
# Training
# -----------------------------------------------------------------------------
echo "========================================"
echo "Starting Crop Recommendation Training..."
echo "========================================"

# Set environment variables
export PYTHONFAULTHANDLER=1
export CUDA_LAUNCH_BLOCKING=0

# Run training (both XGBoost and Neural Network)
python "${SRC_DIR}/train_recommendation.py" \
    --data "${DATA_DIR}/crop_data.csv" \
    --checkpoint-dir "${CHECKPOINT_DIR}" \
    --epochs 100

TRAINING_EXIT_CODE=$?

# -----------------------------------------------------------------------------
# Post-processing
# -----------------------------------------------------------------------------
if [ $TRAINING_EXIT_CODE -eq 0 ]; then
    echo "========================================"
    echo "Training completed successfully!"
    echo "========================================"
    
    # Sync checkpoints
    if [ -d "${CHECKPOINT_DIR}" ]; then
        echo "Syncing checkpoints..."
        rsync -av --progress "${CHECKPOINT_DIR}/" "${WORK_DIR}/checkpoints_backup/recommendation_${SLURM_JOB_ID}/"
    fi
    
    # Display results
    python << EOF
import json
import os

checkpoint_dir = "${CHECKPOINT_DIR}"
metrics_path = os.path.join(checkpoint_dir, "metrics.json")

if os.path.exists(metrics_path):
    with open(metrics_path, 'r') as f:
        metrics = json.load(f)
    print("\nTraining Results:")
    print("-" * 40)
    for model_type, model_metrics in metrics.items():
        if isinstance(model_metrics, dict) and 'accuracy' in model_metrics:
            print(f"\n{model_type.upper()}:")
            print(f"  Accuracy: {model_metrics['accuracy']:.4f}")
            print(f"  F1 Score: {model_metrics['f1_score']:.4f}")
            print(f"  Precision: {model_metrics['precision']:.4f}")
            print(f"  Recall: {model_metrics['recall']:.4f}")
else:
    print("Metrics file not found.")
EOF

else
    echo "========================================"
    echo "Training failed with exit code: $TRAINING_EXIT_CODE"
    echo "========================================"
fi

# -----------------------------------------------------------------------------
# Cleanup and Exit
# -----------------------------------------------------------------------------
echo "========================================"
echo "Job finished at: $(date)"
echo "========================================"

exit $TRAINING_EXIT_CODE
