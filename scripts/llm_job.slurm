#!/bin/bash
# =============================================================================
# SLURM Job Script: Agricultural LLM Fine-tuning
# =============================================================================
# This script submits the QLoRA fine-tuning job for Qwen 2.5 7B to CINECA Leonardo.
# Uses DeepSpeed ZeRO-2 for efficient multi-GPU training.
#
# Submit with: sbatch llm_job.slurm
# Monitor with: squeue -u $USER
# Cancel with: scancel <job_id>
# Check GPU usage: srun --jobid=<job_id> nvidia-smi
# =============================================================================

# -----------------------------------------------------------------------------
# SLURM Directives
# -----------------------------------------------------------------------------
#SBATCH --job-name=growai-llm
#SBATCH --output=../logs/llm_%j.out
#SBATCH --error=../logs/llm_%j.err
#SBATCH --time=12:00:00
#SBATCH --partition=boost_usr_prod
#SBATCH --nodes=1
#SBATCH --ntasks-per-node=1
#SBATCH --gpus-per-node=4
#SBATCH --cpus-per-task=32
#SBATCH --mem=200G
#SBATCH --mail-type=BEGIN,END,FAIL
#SBATCH --mail-user=$USER@cineca.it

# -----------------------------------------------------------------------------
# Environment Setup
# -----------------------------------------------------------------------------
echo "========================================"
echo "Job started at: $(date)"
echo "Running on host: $(hostname)"
echo "SLURM_JOB_ID: $SLURM_JOB_ID"
echo "SLURM_NODELIST: $SLURM_NODELIST"
echo "CUDA_VISIBLE_DEVICES: $CUDA_VISIBLE_DEVICES"
echo "========================================"

# Load modules
module purge
module load profile/deeplearning
module load cuda/12.2
module load cudnn/8.9.7.29-cuda-12.2
module load nccl/2.18.5-cuda-12.2
module load openmpi/4.1.6--gcc--12.2.0
module load gcc/12.2.0

# Source conda
source "${CONDA_DIR}/etc/profile.d/conda.sh" 2>/dev/null || \
source "${HOME}/.conda/etc/profile.d/conda.sh" 2>/dev/null || \
module load anaconda3

# Activate environment
conda activate growai-hpc

# Verify environment
echo "Python: $(which python)"
echo "Python version: $(python --version)"
echo "PyTorch version: $(python -c 'import torch; print(torch.__version__)')"
echo "CUDA available: $(python -c 'import torch; print(torch.cuda.is_available())')"
echo "GPU count: $(python -c 'import torch; print(torch.cuda.device_count())')"

# Check GPU memory
nvidia-smi

# -----------------------------------------------------------------------------
# Configuration
# -----------------------------------------------------------------------------
WORK_DIR="${WORK}/growai-hpc"
SCRATCH_DIR="${SCRATCH}/growai-hpc"
SRC_DIR="${WORK_DIR}/src"
CONFIG_DIR="${WORK_DIR}/configs"
DATA_DIR="${SCRATCH_DIR}/data"
CHECKPOINT_DIR="${WORK_DIR}/checkpoints/llm"
LOG_DIR="${WORK_DIR}/logs/llm"
CACHE_DIR="${SCRATCH_DIR}/cache"

# Create directories
mkdir -p "${CHECKPOINT_DIR}"
mkdir -p "${LOG_DIR}"
mkdir -p "${DATA_DIR}"
mkdir -p "${CACHE_DIR}"

# Hugging Face cache
export HF_HOME="${CACHE_DIR}/huggingface"
export TRANSFORMERS_CACHE="${CACHE_DIR}/transformers"
export HF_DATASETS_CACHE="${CACHE_DIR}/datasets"

# -----------------------------------------------------------------------------
# Data Preparation
# -----------------------------------------------------------------------------
if [ ! -f "${DATA_DIR}/llm_training.jsonl" ]; then
    echo "LLM training data not found. It will be generated by the training script."
fi

# -----------------------------------------------------------------------------
# Training
# -----------------------------------------------------------------------------
echo "========================================"
echo "Starting LLM Fine-tuning..."
echo "Model: Qwen/Qwen2.5-7B"
echo "Method: QLoRA with DeepSpeed ZeRO-2"
echo "========================================"

# Set environment variables for distributed training
export PYTHONFAULTHANDLER=1
export CUDA_LAUNCH_BLOCKING=0
export NCCL_DEBUG=INFO
export NCCL_IB_DISABLE=0
export NCCL_SOCKET_IFNAME=ib0
export TORCH_DISTRIBUTED_DEBUG=DETAIL

# DeepSpeed environment
export MASTER_ADDR=$(hostname)
export MASTER_PORT=29500
export WORLD_SIZE=$SLURM_NTASKS
export RANK=$SLURM_PROCID

# Run training with DeepSpeed
# Using torchrun for proper multi-GPU initialization
torchrun \
    --nnodes=1 \
    --nproc_per_node=4 \
    --rdzv_id=$SLURM_JOB_ID \
    --rdzv_backend=c10d \
    --rdzv_endpoint=$MASTER_ADDR:29500 \
    "${SRC_DIR}/train_llm.py" \
    --data "${DATA_DIR}/llm_training.jsonl" \
    --output-dir "${CHECKPOINT_DIR}" \
    --epochs 3 \
    --deepspeed 2

TRAINING_EXIT_CODE=$?

# -----------------------------------------------------------------------------
# Post-processing
# -----------------------------------------------------------------------------
if [ $TRAINING_EXIT_CODE -eq 0 ]; then
    echo "========================================"
    echo "Training completed successfully!"
    echo "========================================"
    
    # Merge LoRA weights with base model for easier deployment
    echo "Merging LoRA weights with base model..."
    python << 'PYTHON_EOF'
import os
import torch
from peft import PeftModel, PeftConfig
from transformers import AutoModelForCausalLM, AutoTokenizer

checkpoint_dir = os.environ.get('CHECKPOINT_DIR')
final_dir = os.path.join(checkpoint_dir, 'final')
merged_dir = os.path.join(checkpoint_dir, 'merged')

if os.path.exists(final_dir):
    try:
        # Load base model
        base_model = AutoModelForCausalLM.from_pretrained(
            'Qwen/Qwen2.5-7B',
            torch_dtype=torch.bfloat16,
            device_map='auto'
        )
        tokenizer = AutoTokenizer.from_pretrained('Qwen/Qwen2.5-7B')
        
        # Load and merge LoRA
        model = PeftModel.from_pretrained(base_model, final_dir)
        model = model.merge_and_unload()
        
        # Save merged model
        os.makedirs(merged_dir, exist_ok=True)
        model.save_pretrained(merged_dir)
        tokenizer.save_pretrained(merged_dir)
        
        print(f"Merged model saved to {merged_dir}")
    except Exception as e:
        print(f"Error merging model: {e}")
else:
    print("Final checkpoint not found, skipping merge.")
PYTHON_EOF

    # Sync checkpoints to permanent storage
    echo "Syncing checkpoints to backup..."
    rsync -av --progress "${CHECKPOINT_DIR}/" "${WORK_DIR}/checkpoints_backup/llm_${SLURM_JOB_ID}/"
    
    # Calculate model size
    echo ""
    echo "Model Size:"
    du -sh "${CHECKPOINT_DIR}/final" 2>/dev/null || echo "Final model directory not found"
    du -sh "${CHECKPOINT_DIR}/merged" 2>/dev/null || echo "Merged model directory not found"
    
else
    echo "========================================"
    echo "Training failed with exit code: $TRAINING_EXIT_CODE"
    echo "========================================"
    
    # List checkpoint files for debugging
    echo "Checkpoint directory contents:"
    ls -la "${CHECKPOINT_DIR}/" 2>/dev/null || echo "No checkpoints created"
fi

# -----------------------------------------------------------------------------
# Cleanup and Exit
# -----------------------------------------------------------------------------
# Clean up temporary cache if needed (keep HF cache for resuming)
# rm -rf "${CACHE_DIR}/tmp" 2>/dev/null || true

echo "========================================"
echo "Job finished at: $(date)"
echo "========================================"

exit $TRAINING_EXIT_CODE
